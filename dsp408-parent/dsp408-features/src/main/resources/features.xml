<features name="de.drremote.dsp408.features"
          xmlns="http://karaf.apache.org/xmlns/features/v1.6.0">

    <feature name="dsp408-runtime" version="${project.version}">
        <bundle>mvn:de.drremote/dsp408-api/${project.version}</bundle>
        <bundle>mvn:de.drremote/dsp408-core/${project.version}</bundle>
        <bundle>mvn:de.drremote/dsp408-runtime/${project.version}</bundle>
    </feature>

    <feature name="dsp408-shell" version="${project.version}">
        <feature>dsp408-runtime</feature>
        <bundle>mvn:de.drremote/dsp408-shell/${project.version}</bundle>
    </feature>

    <feature name="dsp408-matrix" version="${project.version}">
        <feature>dsp408-runtime</feature>
        <bundle>mvn:com.fasterxml.jackson.core/jackson-annotations/${jackson.version}</bundle>
        <bundle>mvn:com.fasterxml.jackson.core/jackson-core/${jackson.version}</bundle>
        <bundle>mvn:com.fasterxml.jackson.core/jackson-databind/${jackson.version}</bundle>
        <bundle>mvn:de.drremote/dsp408-matrix/${project.version}</bundle>
    </feature>

    <feature name="dsp408-http" version="${project.version}">
        <feature>http</feature>
        <feature>dsp408-runtime</feature>
        <bundle>mvn:com.fasterxml.jackson.core/jackson-annotations/${jackson.version}</bundle>
        <bundle>mvn:com.fasterxml.jackson.core/jackson-core/${jackson.version}</bundle>
        <bundle>mvn:com.fasterxml.jackson.core/jackson-databind/${jackson.version}</bundle>
        <bundle>mvn:de.drremote/dsp408-http/${project.version}</bundle>
    </feature>

    <feature name="dsp408-all" version="${project.version}">
        <feature>dsp408-runtime</feature>
        <feature>dsp408-shell</feature>
        <feature>dsp408-matrix</feature>
        <feature>dsp408-http</feature>
    </feature>
</features>
